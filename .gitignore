# ═══════════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
ENV/
env/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# ═══════════════════════════════════════════════════════════════════
# Large Data Files
# ═══════════════════════════════════════════════════════════════════
# The BRFSS 2014 dataset is ~400 MB — far too large for version control.
# Download it separately (see README for instructions).
*.csv

# ═══════════════════════════════════════════════════════════════════
# IDE & Editor Configs
# ═══════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ═══════════════════════════════════════════════════════════════════
# OS Generated Files
# ═══════════════════════════════════════════════════════════════════
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*

# ═══════════════════════════════════════════════════════════════════
# Jupyter Notebooks (checkpoints)
# ═══════════════════════════════════════════════════════════════════
.ipynb_checkpoints/

# ═══════════════════════════════════════════════════════════════════
# Logs & Misc
# ═══════════════════════════════════════════════════════════════════
*.log
*.out
*.bak
*.tmp

# ═══════════════════════════════════════════════════════════════════
# Compiled Binaries (unrelated to this project)
# ═══════════════════════════════════════════════════════════════════
*.exe
*.class
*.o
*.a
